# ─────────────────────────────────────────────────────────────────────────────
# BAPPERIDA Kalimantan Tengah - Environment Variables
# Salin ke Replit Secrets (ikon kunci 🔐 di sidebar)
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=127.0.0.1

# ─── File / Upload URL Base ───────────────────────────────────────────────────
# URL dasar untuk akses file yang diupload (gambar, dokumen, dll).
# Kosongkan / jangan diisi → URL file bersifat relatif (/uploads/...) dan
# dilayani langsung dari server ini (default).
# Isi dengan URL server lain → semua URL file akan menggunakan base ini.
# Contoh: https://storage.bapperida.kalteng.go.id
#         https://cdn.example.com
# FILE_BASE_URL=

# ─── Security ─────────────────────────────────────────────────────────────────
SESSION_SECRET=bb234eb625254c9079bffb8561f394067212d326b58d428960105d6d3d488be8

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DB_NAME
RUN_SEED=true
SEED_ADMIN_PASSWORD=Admin@123
DATABASE_URL=mysql://root:simple159@127.0.0.1:3306/bapperida_db

# ─── TinyMCE ─────────────────────────────────────────────────────────────────
VITE_TINYMCE_API_KEY=n6orr52fyuwpmh2yqlhh3ng0nqd9lwauyg0jowt7vr4twq5g

# ─────────────────────────────────────────────────────────────────────────────
# FIREBASE CLOUD MESSAGING (FCM) — Push Notifications
# ─────────────────────────────────────────────────────────────────────────────
#
# LANGKAH SETUP:
# 1. Buka https://console.firebase.google.com
# 2. Klik "Add project" → beri nama → ikuti wizard
# 3. Di dashboard project, klik gear ⚙️ → "Project settings"
#
# ─── Step 1: Web App Config (untuk frontend browser) ────────────────────────
# Di "Project settings" → tab "General" → scroll ke "Your apps"
# Klik "</>" (Web) → beri nickname → klik "Register app"
# Salin nilai dari firebaseConfig:
VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdefabcdefabcdef

# ─── Step 2: VAPID Key (untuk Web Push / browser push notification) ──────────
# Di "Project settings" → tab "Cloud Messaging"
# Scroll ke "Web configuration" → klik "Generate key pair"
# Salin nilai kolom "Key pair" (bukan "Key ID")
VITE_FIREBASE_VAPID_KEY=BNtXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Step 3: Service Account JSON (untuk backend mengirim push) ───────────────
# Di "Project settings" → tab "Service accounts"
# Klik "Generate new private key" → download file JSON
#
# CARA CONVERT JSON KE SATU BARIS (wajib):
# Buka terminal di komputer, jalankan:
#   node -e "console.log(JSON.stringify(require('./serviceAccountKey.json')))"
# Copy seluruh output (tanpa quotes awal/akhir) ke Secret FIREBASE_SERVICE_ACCOUNT
#
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"xxxxx","private_key":"-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com","client_id":"123456789","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxx%40your-project.iam.gserviceaccount.com"}

# ─────────────────────────────────────────────────────────────────────────────
# CARA MENAMBAHKAN SECRETS DI REPLIT:
# 1. Klik ikon kunci 🔐 di sidebar kiri Replit
# 2. Klik "+ New secret"
# 3. Key: nama variabel (contoh: VITE_FIREBASE_API_KEY)
#    Value: nilai dari file ini
# 4. Ulangi untuk setiap variabel Firebase
# 5. Klik tombol Restart (▶) untuk restart aplikasi
# ─────────────────────────────────────────────────────────────────────────────
#
# UNTUK FLUTTER (Mobile App):
# Setelah login, panggil:
#   POST /api/v1/fcm/token
#   Body: { "token": "<FCM_TOKEN_DARI_FIREBASE_FLUTTER>", "device_type": "android" }
# Ini mendaftarkan device untuk menerima push notification dari admin portal.
# ─────────────────────────────────────────────────────────────────────────────
